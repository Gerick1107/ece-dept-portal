# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/.venv/
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.log

# Secrets & environment (never commit real credentials)
backend/.env
.env
.env.*
!.env.example
!.env.docker.example
!backend/.env.example

# Backend runtime storage (uploads, CO-PO results, notification attachments)
backend/storage/
storage/

# Confidential meeting PDFs (folder structure is tracked; files are not)
backend/documents/**/*.pdf
backend/documents/_upload_temp/

# Node / frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.*
!frontend/.env.example
*.tsbuildinfo

# IDE & OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Cursor / local tooling
.cursor/
*.local

# Database dumps & local SQL (may contain real data)
*.sql
!data/sql/local_mysql_bootstrap.sql
dump.sql
*.sql.gz

# Docker local overrides (compose secrets stay in .env.docker, gitignored above)
docker-compose.override.yml

# Department data assets (CSVs, mapping Excel, Links.txt) — NOT in Git; share via SQL dump / secure copy
data/assets/*
!data/assets/.gitkeep

# Legacy runtime uploads (reference tree)
uploads/*
!uploads/.gitkeep

# Test / scratch spreadsheets at repo root only
projects_seeded.xlsx
*.xlsx
!data/templates/*.xlsx

# Compiled / cache (incl. ML model download cache)
*.pyc
.cache/
.huggingface/
