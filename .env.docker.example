# Copy to .env.docker and fill in before: docker compose --env-file .env.docker up -d --build

MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_USER=portal_user
MYSQL_PASSWORD=replace_with_strong_portal_password
MYSQL_DATABASE=ece_dept_portal

# openssl rand -hex 32
SECRET_KEY=replace_with_64_char_hex_secret

BOOTSTRAP_ADMIN_EMAIL=admin@ece.iiitd.ac.in
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeOnFirstLogin!

# Public URL users will open in the browser
PORTAL_FRONTEND_URL=http://your-server.example.edu
CORS_ORIGINS=http://your-server.example.edu

PORTAL_HTTP_PORT=8080

ENABLE_SCHEDULER=false
ENABLE_REQUIREMENT_REMINDERS=true
REQUIREMENT_REMINDER_POLL_MINUTES=1

# ── LLM providers ──
# Cloud (Groq). Model is config-driven; bump GROQ_MODEL on a model deprecation.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
# Keep prompt(~2k tokens) + this under the Groq model's TPM limit (free tier = 8000)
# or Groq rejects insight generation with HTTP 413. Raise on a paid tier.
LLM_INSIGHTS_MAX_TOKENS=5000
LOCAL_LLM_INSIGHTS_MAX_TOKENS=2000
# Local (Ollama). Runs on the HOST, so inside Docker use host.docker.internal.
# Install Ollama on the host and `ollama pull llama3.2:3b` first.
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_MODEL=llama3.2:3b
DEFAULT_LLM_PROVIDER=groq
# SDG auto-tagging for BTP/IP projects (local embeddings, no API key needed).
# First use downloads the embedding model (~1.3 GB), cached in the hf_cache volume.
ENABLE_SDG_LLM=true
SDG_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
SDG_TOP_K=5
SDG_REQUEST_DELAY_SECONDS=0.5

# ── Email (welcome mails, password reset, requirement reminders) ──
# Leave SMTP_ENABLED=false to skip email entirely. To send, set it true and fill creds
# (for Gmail use an App Password, not the account password).
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ── Publications scraping ──
# The container has no browser, so the "scholarly" backend can't run; use serpapi.
# SERP_API_KEYS is a comma-separated list (keys are rotated as budgets are used up).
SCRAPER_BACKEND=serpapi
SERP_API_KEY=
SERP_API_KEYS=
