APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Windows MySQL Server 8.0 — port 3306 (3307 was Docker only). See docs/LOCAL_DATABASE.md
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=portal_user
MYSQL_PASSWORD=portal_pass
MYSQL_DATABASE=ece_dept_portal
# Optional production override (leave empty for local dev):
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/ece_dept_portal

UPLOAD_DIR=./storage/uploads
RESULTS_DIR=./storage/results
ARCHIVE_DIR=./storage/archives
# Confidential Senate / faculty-meet PDFs (gitignored — local or server only)
# DOCUMENTS_DIR=./documents
FILE_MAX_AGE_SECONDS=1800

# Leave empty — auto-resolved from data/assets/ or project root
# DEFAULT_MAPPING_PATH=
# DEFAULT_INDIRECT_PATH=

BOOTSTRAP_ADMIN_EMAIL=admin@ece.iiitd.ac.in
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeOnFirstLogin!

PORTAL_FRONTEND_URL=http://localhost:5173

# SMTP — faculty welcome email and requirement reminder emails
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ece.iiitd.ac.in

# Publications scraper — use serpapi when Google Scholar blocks scholarly
SERP_API_KEY=
SCRAPER_BACKEND=scholarly

# LLM insights — Groq API for CO-PO comparison narratives
# Optional: enable background publication sync scheduler
# ENABLE_SCHEDULER=true
# Requirement auto-reminders (email until tracker is green). On by default.
ENABLE_REQUIREMENT_REMINDERS=true
REQUIREMENT_REMINDER_POLL_MINUTES=1
ENABLE_SDG_LLM=false
SDG_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
SDG_TOP_K=5
SDG_REQUEST_DELAY_SECONDS=0.5
GROQ_API_KEY=your_groq_api_key